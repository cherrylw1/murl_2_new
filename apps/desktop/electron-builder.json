{
  "appId": "com.murl.desktop",
  "productName": "Murl",
  "directories": {
    "output": "dist"
  },
  "files": [
    "out/**/*",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "resources/icon.png",
      "to": "icon.png"
    }
  ],
  "asar": true,
  "asarUnpack": [
    "**/node-pty/**/*"
  ],
  "npmRebuild": false,
  "win": {
    "target": [
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.png"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.png",
    "category": "public.app-category.developer-tools"
  },
  "portable": {
    "artifactName": "Murl-Portable-${version}.${ext}"
  }
}
